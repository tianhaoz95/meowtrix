{
  "name": "meowtrix",
  "version": "1.0.0",
  "description": "Meowtrix — remote vibe engineering tool with split panes, terminals, and browser",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "docker": "./docker-run.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:docker": "docker compose -f docker-compose.test.yml up --build --exit-code-from playwright"
  },
  "dependencies": {
    "express": "4.18.2",
    "ws": "8.16.0",
    "node-pty": "1.0.0",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
