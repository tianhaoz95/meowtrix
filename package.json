{
  "name": "meowtrix",
  "version": "1.16.12",
  "description": "Meowtrix — remote vibe engineering tool with split panes, terminals, and browser",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "docker": "./docker-run.sh",
    "test:e2e": "rm -rf test-results playwright-report && playwright test",
    "test:e2e:ui": "rm -rf test-results playwright-report && playwright test --ui",
    "test:e2e:docker": "rm -rf test-results playwright-report && docker compose -f docker-compose.test.yml down -v && docker compose -f docker-compose.test.yml up --build --exit-code-from playwright",
    "screenshots": "npx playwright test --config=playwright.screenshots.config.js --project=chromium screenshots.spec.js",
    "gifs": "npx playwright test --config=playwright.screenshots.config.js --project=chromium features.spec.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "4.18.2",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "node-pty": "1.0.0",
    "uuid": "9.0.0",
    "ws": "8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
